javascript:(function () { if (!/linkedin\.com/i.test(location.hostname)) { alert('IEEE DataPort Capture: open a LinkedIn post page first.'); return; } function cleanText(node) { if (!node) return ''; return (node.innerText || node.textContent || '') .replace(/\s+/g, ' ') .trim(); } function firstText(selectors) { for (var i = 0; i < selectors.length; i++) { var el = document.querySelector(selectors[i]); var text = cleanText(el); if (text) return text; } return ''; } function firstHref(selectors) { for (var j = 0; j < selectors.length; j++) { var link = document.querySelector(selectors[j]); if (link && link.href) return link.href.split('?')[0]; } return ''; } var postUrl = location.href.split('?')[0].split('#')[0]; var text = firstText([ '.feed-shared-update-v2__description .break-words', '.update-components-text .break-words', '.feed-shared-inline-show-more-text', '[data-test-id="main-feed-activity-card"] .break-words', '.share-update-card .break-words', 'div[data-urn*="activity"] .break-words', ]); var displayName = firstText([ '.update-components-actor__title span[aria-hidden="true"]', '.update-components-actor__title', '.feed-shared-actor__name', '.feed-shared-actor__title', ]); var affiliation = firstText([ '.update-components-actor__description', '.feed-shared-actor__description', ]); var profileUrl = firstHref([ '.update-components-actor__meta-link', '.feed-shared-actor__container-link', 'a.app-aware-link[href*="/in/"]', ]); if (!text) { alert( 'Could not read post text on this page.\n\n' + 'Try opening the full post (not just the feed card), then run the bookmarklet again.' ); return; } if (!displayName) displayName = 'Unknown author'; var today = new Date().toISOString().slice(0, 10); var tags = /#ieeedataport/i.test(text) ? 'ieeedataport' : 'ieeedataport'; function csvEscape(value) { var s = (value || '').replace(/\r?\n/g, ' ').trim(); if (/[",\n\r]/.test(s)) return '"' + s.replace(/"/g, '""') + '"'; return s; } var fields = [ '', today, 'ieeedataport', postUrl, profileUrl, displayName, affiliation, text, 'testimonial', '', '', '', '', tags, 'public_hashtag', 'Captured with IEEE DataPort editor bookmarklet', '', ]; var csvLine = fields.map(csvEscape).join(','); function copyLine() { if (navigator.clipboard && navigator.clipboard.writeText) { return navigator.clipboard.writeText(csvLine); } return Promise.reject(new Error('clipboard unavailable')); } copyLine() .then(function () { alert( 'CSV row copied to clipboard.\n\n' + displayName + '\n\nPaste as a new line in data/linkedin-staging.csv, then commit and push.' ); }) .catch(function () { prompt('Copy this CSV row into data/linkedin-staging.csv:', csvLine); }); })();