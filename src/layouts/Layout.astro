---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'IEEE DataPort Member Voices',
  description = 'A curated showcase of public reflections and testimonials about IEEE DataPort, with consent-based attribution.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={import.meta.env.BASE_URL}>
          <span class="brand-mark">IEEE</span>
          <span class="brand-text">DataPort Voices</span>
        </a>
        <nav class="nav">
          <a href={import.meta.env.BASE_URL}>Showcase</a>
          <a href={`${import.meta.env.BASE_URL}insights/`}>Insights</a>
          <a href={`${import.meta.env.BASE_URL}moderation/`}>Moderation</a>
          <a href={`${import.meta.env.BASE_URL}submit/`}>Submit</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>
          Curated member-engagement showcase. Only approved, consented content is published.
        </p>
        <p class="muted">
          Data updated from <code>data/entries.json</code> · Hosted on GitHub Pages
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f9fc;
    --surface: #ffffff;
    --text: #1a2332;
    --muted: #5c6b7f;
    --border: #d9e2ef;
    --accent: #00629b;
    --accent-soft: #e8f4fa;
    --positive: #1f7a4d;
    --mixed: #b86e00;
    --neutral: #5c6b7f;
    --negative: #b42318;
    --shadow: 0 8px 24px rgba(26, 35, 50, 0.08);
    --radius: 12px;
    --font: "Segoe UI", system-ui, -apple-system, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
  }

  a {
    color: var(--accent);
  }

  code {
    font-size: 0.9em;
    background: #eef3f8;
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .container {
    width: min(1100px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .site-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    gap: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
    font-weight: 700;
  }

  .brand-mark {
    background: var(--accent);
    color: white;
    padding: 0.2rem 0.45rem;
    border-radius: 6px;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }

  .nav {
    display: flex;
    gap: 1rem;
  }

  .nav a {
    text-decoration: none;
    color: var(--muted);
    font-weight: 600;
  }

  .nav a:hover {
    color: var(--accent);
  }

  main.container {
    padding: 2rem 0 3rem;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 1.5rem 0 2rem;
    font-size: 0.92rem;
  }

  .muted {
    color: var(--muted);
  }

  .hero {
    margin-bottom: 2rem;
  }

  .hero h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    line-height: 1.2;
  }

  .hero p {
    margin: 0;
    color: var(--muted);
    max-width: 65ch;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: var(--shadow);
  }

  .stat-card strong {
    display: block;
    font-size: 1.6rem;
    line-height: 1.1;
  }

  .stat-card span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow);
    margin-bottom: 1.5rem;
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 720px) {
    .grid.two-col {
      grid-template-columns: 1fr 1fr;
    }
  }

  .badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge.positive { background: #e8f6ee; color: var(--positive); }
  .badge.mixed { background: #fff4e5; color: var(--mixed); }
  .badge.neutral { background: #eef2f7; color: var(--neutral); }
  .badge.negative { background: #fdecea; color: var(--negative); }

  .empty {
    text-align: center;
    color: var(--muted);
    padding: 2rem 1rem;
  }
</style>
