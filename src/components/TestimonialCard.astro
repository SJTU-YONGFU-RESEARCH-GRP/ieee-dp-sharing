---
import type { Entry } from '../lib/types';
import { TOPIC_LABELS } from '../lib/types';

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const quote = entry.enrichment?.quote ?? entry.text;
const sentiment = entry.enrichment?.sentiment;
const topics = entry.enrichment?.topics ?? entry.tags ?? [];
const dateLabel = entry.published_at ?? entry.submitted_at;
---

<article class="card" data-entry-id={entry.id}>
  {entry.featured && <span class="featured-pill">Featured</span>}
  <blockquote class="quote">"{quote}"</blockquote>
  <div class="meta">
    <strong>{entry.display_name}</strong>
    {entry.affiliation && <span class="affiliation"> · {entry.affiliation}</span>}
  </div>
  <div class="chips">
    {sentiment && <span class={`badge ${sentiment}`}>{sentiment}</span>}
    {entry.post_type && <span class="chip">{entry.post_type}</span>}
    {entry.region && <span class="chip">{entry.region}</span>}
    {topics.slice(0, 4).map((topic) => (
      <span class="chip topic">{TOPIC_LABELS[topic] ?? topic}</span>
    ))}
  </div>
  <footer class="card-footer">
    <time datetime={dateLabel}>{dateLabel}</time>
    {entry.source_url ? (
      <a href={entry.source_url} target="_blank" rel="noopener noreferrer">View source</a>
    ) : (
      <span class="muted">Curated submission</span>
    )}
  </footer>
</article>

<style>
  .card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow);
  }

  .featured-pill {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
  }

  .quote {
    margin: 0 0 1rem;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--text);
  }

  .meta {
    margin-bottom: 0.75rem;
  }

  .affiliation {
    color: var(--muted);
    font-weight: 500;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.9rem;
  }

  .chip {
    background: #f0f4f8;
    color: var(--muted);
    font-size: 0.78rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .chip.topic {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }

  .card-footer a {
    font-weight: 600;
    text-decoration: none;
  }

  .card-footer a:hover {
    text-decoration: underline;
  }
</style>
